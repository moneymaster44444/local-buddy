# Copy this file to `.env` and edit as needed. Every setting is optional —
# the defaults shown here work out of the box with a local LM Studio server.

# --- LM Studio (OpenAI-compatible server) ---
LOCALBUDDY_BASE_URL=http://localhost:1234/v1
LOCALBUDDY_API_KEY=lm-studio
LOCALBUDDY_REQUEST_TIMEOUT=120

# --- Model selection ---
# Pin model ids to skip the interactive picker. Run LocalBuddy once without
# these to see the exact ids LM Studio reports, then paste them here.
# If unset (or not currently loaded), LocalBuddy prompts you to choose.
#LOCALBUDDY_BRAIN_MODEL_ID=
#LOCALBUDDY_UTILITY_MODEL_ID=

# --- Rolling history summarization ---
# When estimated tokens exceed the budget, older turns are condensed by the
# utility model. Token size is estimated as characters / CHARS_PER_TOKEN.
LOCALBUDDY_HISTORY_TOKEN_BUDGET=6000
LOCALBUDDY_KEEP_RECENT_TURNS=4
LOCALBUDDY_CHARS_PER_TOKEN=4.0
LOCALBUDDY_SUMMARY_MAX_TOKENS=512
